# Copy to `.env.local` (gitignored) and fill the keys from your Supabase
# project's dashboard under Project Settings → API.

# Client-exposed — safe to ship to the browser. ONLY the URL and anon key may
# carry the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY — used in server route handlers that legitimately bypass RLS
# (e.g. user invitations). NEVER expose to the client and NEVER add a
# NEXT_PUBLIC_ prefix. A service-role key in client code is a phase-blocking bug.
SUPABASE_SERVICE_ROLE_KEY=
