{
  "_comment": "Shared test vectors for the section-visibility condition evaluator. Consumed by BOTH the SQL evaluator test (supabase/tests/20_conditions.sql) and the TypeScript mirror test (src/lib/queries/conditions.test.ts). Keeping the two in agreement is enforced by these vectors; drift is a phase-blocking bug. `answers` maps question_key -> answer value (jsonb). `visible_when` follows ARCHITECTURE visible_when shape; null means always-visible.",
  "vectors": [
    {
      "name": "null condition is always visible",
      "visible_when": null,
      "answers": { "q1": "Sim" },
      "expected": true
    },
    {
      "name": "equals match",
      "visible_when": { "question_key": "q1", "op": "equals", "value": "Sim" },
      "answers": { "q1": "Sim" },
      "expected": true
    },
    {
      "name": "equals mismatch",
      "visible_when": { "question_key": "q1", "op": "equals", "value": "Sim" },
      "answers": { "q1": "Não" },
      "expected": false
    },
    {
      "name": "equals missing answer is false",
      "visible_when": { "question_key": "q1", "op": "equals", "value": "Sim" },
      "answers": {},
      "expected": false
    },
    {
      "name": "equals null answer is false",
      "visible_when": { "question_key": "q1", "op": "equals", "value": "Sim" },
      "answers": { "q1": null },
      "expected": false
    },
    {
      "name": "not_equals mismatch is true",
      "visible_when": {
        "question_key": "q1",
        "op": "not_equals",
        "value": "Sim"
      },
      "answers": { "q1": "Não" },
      "expected": true
    },
    {
      "name": "not_equals match is false",
      "visible_when": {
        "question_key": "q1",
        "op": "not_equals",
        "value": "Sim"
      },
      "answers": { "q1": "Sim" },
      "expected": false
    },
    {
      "name": "not_equals missing answer is true",
      "visible_when": {
        "question_key": "q1",
        "op": "not_equals",
        "value": "Sim"
      },
      "answers": {},
      "expected": true
    },
    {
      "name": "in match scalar",
      "visible_when": {
        "question_key": "q1",
        "op": "in",
        "value": ["A", "B", "C"]
      },
      "answers": { "q1": "B" },
      "expected": true
    },
    {
      "name": "in mismatch scalar",
      "visible_when": {
        "question_key": "q1",
        "op": "in",
        "value": ["A", "B", "C"]
      },
      "answers": { "q1": "D" },
      "expected": false
    },
    {
      "name": "in missing answer is false",
      "visible_when": { "question_key": "q1", "op": "in", "value": ["A", "B"] },
      "answers": {},
      "expected": false
    },
    {
      "name": "equals against checkbox array (selected option present)",
      "visible_when": {
        "question_key": "q1",
        "op": "equals",
        "value": "luvas"
      },
      "answers": { "q1": ["luvas", "avental"] },
      "expected": true
    },
    {
      "name": "equals against checkbox array (option absent)",
      "visible_when": {
        "question_key": "q1",
        "op": "equals",
        "value": "mascara"
      },
      "answers": { "q1": ["luvas", "avental"] },
      "expected": false
    },
    {
      "name": "not_equals against checkbox array (option absent is true)",
      "visible_when": {
        "question_key": "q1",
        "op": "not_equals",
        "value": "mascara"
      },
      "answers": { "q1": ["luvas", "avental"] },
      "expected": true
    },
    {
      "name": "in against checkbox array (any selected option in list)",
      "visible_when": {
        "question_key": "q1",
        "op": "in",
        "value": ["mascara", "avental"]
      },
      "answers": { "q1": ["luvas", "avental"] },
      "expected": true
    },
    {
      "name": "in against checkbox array (no selected option in list)",
      "visible_when": {
        "question_key": "q1",
        "op": "in",
        "value": ["mascara", "touca"]
      },
      "answers": { "q1": ["luvas", "avental"] },
      "expected": false
    },
    {
      "name": "equals numeric value",
      "visible_when": { "question_key": "q1", "op": "equals", "value": 3 },
      "answers": { "q1": 3 },
      "expected": true
    },
    {
      "name": "equals boolean value",
      "visible_when": { "question_key": "q1", "op": "equals", "value": true },
      "answers": { "q1": true },
      "expected": true
    },
    {
      "name": "gt numeric true",
      "visible_when": { "question_key": "q1", "op": "gt", "value": 5 },
      "answers": { "q1": 7 },
      "expected": true
    },
    {
      "name": "gt numeric false (equal)",
      "visible_when": { "question_key": "q1", "op": "gt", "value": 5 },
      "answers": { "q1": 5 },
      "expected": false
    },
    {
      "name": "gte numeric true (equal)",
      "visible_when": { "question_key": "q1", "op": "gte", "value": 5 },
      "answers": { "q1": 5 },
      "expected": true
    },
    {
      "name": "gte numeric false",
      "visible_when": { "question_key": "q1", "op": "gte", "value": 5 },
      "answers": { "q1": 4 },
      "expected": false
    },
    {
      "name": "lt numeric true",
      "visible_when": { "question_key": "q1", "op": "lt", "value": 5 },
      "answers": { "q1": 3 },
      "expected": true
    },
    {
      "name": "lte numeric true (equal)",
      "visible_when": { "question_key": "q1", "op": "lte", "value": 5 },
      "answers": { "q1": 5 },
      "expected": true
    },
    {
      "name": "gt numeric with negatives",
      "visible_when": { "question_key": "q1", "op": "gt", "value": -3 },
      "answers": { "q1": -1 },
      "expected": true
    },
    {
      "name": "gte numeric with decimals",
      "visible_when": { "question_key": "q1", "op": "gte", "value": 2.5 },
      "answers": { "q1": 2.5 },
      "expected": true
    },
    {
      "name": "gt missing answer is false",
      "visible_when": { "question_key": "q1", "op": "gt", "value": 5 },
      "answers": {},
      "expected": false
    },
    {
      "name": "lt null answer is false",
      "visible_when": { "question_key": "q1", "op": "lt", "value": 5 },
      "answers": { "q1": null },
      "expected": false
    },
    {
      "name": "gt array (checkbox) answer never orders, false",
      "visible_when": { "question_key": "q1", "op": "gt", "value": 1 },
      "answers": { "q1": [2, 3] },
      "expected": false
    },
    {
      "name": "gte ISO date string sorts as text, true",
      "visible_when": {
        "question_key": "q1",
        "op": "gte",
        "value": "2026-01-01"
      },
      "answers": { "q1": "2026-06-23" },
      "expected": true
    },
    {
      "name": "lt ISO date string sorts as text, false",
      "visible_when": {
        "question_key": "q1",
        "op": "lt",
        "value": "2026-01-01"
      },
      "answers": { "q1": "2026-06-23" },
      "expected": false
    },
    {
      "name": "lt ISO date boundary (strictly before)",
      "visible_when": {
        "question_key": "q1",
        "op": "lt",
        "value": "2026-06-23"
      },
      "answers": { "q1": "2026-06-22" },
      "expected": true
    },
    {
      "name": "gt 24h time string sorts as text, true",
      "visible_when": { "question_key": "q1", "op": "gt", "value": "08:00" },
      "answers": { "q1": "14:30" },
      "expected": true
    },
    {
      "name": "lte 24h time string equal, true",
      "visible_when": { "question_key": "q1", "op": "lte", "value": "23:59" },
      "answers": { "q1": "23:59" },
      "expected": true
    }
  ]
}
