# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# playwright
/test-results/
/playwright-report/
/playwright/.cache/
# ad-hoc run logs captured during gate runs (redirected output, never source)
/playwright-*.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# personal Pictures library accidentally nested under docs/design (not project design assets)
docs/design/Pictures/
